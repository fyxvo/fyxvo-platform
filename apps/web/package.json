{
  "name": "@fyxvo/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "lint": "eslint app components lib test next.config.ts vitest.config.ts --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests && node ./test/firefox-hydration-regression.mjs",
    "perf:budgets": "node ./scripts/performance-budget.mjs",
    "prod:smoke": "node ./scripts/production-smoke.mjs"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari major versions",
    "last 2 Edge versions",
    "not dead"
  ],
  "dependencies": {
    "@fyxvo/config": "workspace:*",
    "@fyxvo/sdk": "workspace:*",
    "@fyxvo/ui": "workspace:*",
    "@phantom/browser-sdk": "^1.0.7",
    "@solana/wallet-adapter-backpack": "^0.1.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-coinbase": "^0.1.23",
    "@solana/wallet-adapter-phantom": "^0.9.28",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-solflare": "^0.6.32",
    "@solana/wallet-adapter-trust": "^0.1.17",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
