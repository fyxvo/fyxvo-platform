{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "paths": {
      "@fyxvo/config": ["../../packages/config/dist/index.js"],
      "@fyxvo/config/pricing": ["../../packages/config/dist/pricing.js"],
      "@fyxvo/sdk": ["../../packages/sdk/src/index.ts"],
      "@fyxvo/ui": ["../../packages/ui/src/index.tsx"]
    }
  },
  "include": ["next-env.d.ts", "app", "components", "lib", "test", ".next/types/**/*.ts", "middleware.ts", "next.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules"]
}
