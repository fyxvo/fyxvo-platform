FYXVO_ENV=production
LOG_LEVEL=info
WORKER_NAME=fyxvo-worker
WORKER_INTERVAL_MS=5000
WORKER_REDIS_PREFIX=fyxvo:worker
WORKER_CONCURRENCY=4
WORKER_REQUEST_LOG_BATCH_SIZE=1000
WORKER_SIGNATURE_BATCH_SIZE=25
WORKER_NODE_TIMEOUT_MS=2500
WORKER_REWARD_WINDOW_MINUTES=60
WORKER_REWARD_LAMPORTS_PER_REQUEST=250
DATABASE_URL=postgresql://postgres:postgres@db-host:5432/fyxvo
REDIS_URL=redis://redis-host:6379
SOLANA_CLUSTER=devnet
FYXVO_PROGRAM_ID=REPLACE_WITH_NEW_GOVERNED_DEVNET_PROGRAM_ID
FYXVO_ADMIN_AUTHORITY=REPLACE_WITH_PROTOCOL_AUTHORITY
FYXVO_AUTHORITY_MODE=governed
FYXVO_PROTOCOL_AUTHORITY=REPLACE_WITH_PROTOCOL_AUTHORITY
FYXVO_PAUSE_AUTHORITY=REPLACE_WITH_PAUSE_AUTHORITY
FYXVO_UPGRADE_AUTHORITY_HINT=REPLACE_WITH_GOVERNED_UPGRADE_AUTHORITY
FYXVO_PROTOCOL_FEE_BPS=500
FYXVO_ENABLE_USDC=false
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com/
REQUEST_TIMEOUT_MS=10000
