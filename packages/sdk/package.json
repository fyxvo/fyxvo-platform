{
  "name": "@fyxvo/sdk",
  "version": "0.2.1",
  "description": "Official TypeScript SDK for the Fyxvo Solana devnet control plane and relay gateway",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "solana",
    "rpc",
    "relay",
    "gateway",
    "jsonrpc",
    "devnet",
    "fyxvo",
    "web3"
  ],
  "author": "Fyxvo <hello@fyxvo.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fyxvo/fyxvo-platform.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://www.fyxvo.com/docs",
  "bugs": {
    "url": "https://github.com/fyxvo/fyxvo-platform/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
