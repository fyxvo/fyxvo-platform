generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum NodeOperatorStatus {
  ACTIVE
  ONBOARDING
  SUSPENDED
}

enum NodeStatus {
  PROVISIONING
  ONLINE
  DEGRADED
  OFFLINE
  DECOMMISSIONED
}

enum NodeNetwork {
  DEVNET
  TESTNET
  MAINNET
}

enum InterestSubmissionStatus {
  NEW
  CONTACTED
  QUALIFIED
  ARCHIVED
}

enum FeedbackCategory {
  BUG_REPORT
  SUPPORT_REQUEST
  ONBOARDING_FRICTION
  PRODUCT_FEEDBACK
}

enum FeedbackSubmissionStatus {
  NEW
  REVIEWING
  FOLLOW_UP
  CLOSED
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  walletAddress      String              @unique
  authNonce          String              @default(uuid())
  sessionVersion     Int                 @default(1)
  email              String?             @unique
  displayName        String
  role               UserRole            @default(MEMBER)
  status             UserStatus          @default(INVITED)
  onboardingDismissed Boolean            @default(false)
  whatsNewDismissedVersion String?
  referralCode       String?             @unique
  // Notification preferences
  notifyProjectActivation Boolean        @default(true)
  notifyApiKeyEvents      Boolean        @default(true)
  notifyFundingConfirmed  Boolean        @default(true)
  notifyLowBalance        Boolean        @default(true)
  notifyDailyAlert        Boolean        @default(true)
  notifyWeeklySummary     Boolean        @default(false)
  notifyReferralConversion Boolean       @default(true)
  tosAcceptedAt            DateTime?
  emailVerified            Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpiry  DateTime?
  reputationLevel          String    @default("Explorer")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  projects           Project[]
  apiKeys            ApiKey[]
  requestLogs        RequestLog[]
  fundingCoordinated FundingCoordinate[]
  notifications      Notification[]
  alertStates        AlertState[]
  referralClicks     ReferralClick[]
  projectMemberships ProjectMember[]
  activityLogs       ActivityLog[]
  supportTickets     SupportTicket[]
  assistantConversations AssistantConversation[]
  assistantFeedback  AssistantFeedback[]
  digestSchedule     DigestSchedule?
  digestRecords      DigestRecord[]

  @@index([referralCode])
}

model InterestSubmission {
  id                    String                   @id @default(uuid()) @db.Uuid
  name                  String
  email                 String
  role                  String
  team                  String?
  useCase               String
  expectedRequestVolume String
  interestAreas         Json
  operatorInterest      Boolean                  @default(false)
  source                String                   @default("web")
  status                InterestSubmissionStatus @default(NEW)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([email, createdAt])
  @@index([status, createdAt])
}

model FeedbackSubmission {
  id            String                   @id @default(uuid()) @db.Uuid
  name          String
  email         String
  role          String?
  team          String?
  walletAddress String?
  projectId     String?                  @db.Uuid
  category      FeedbackCategory
  message       String
  source        String                   @default("web")
  page          String?
  status        FeedbackSubmissionStatus @default(NEW)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  project       Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([status, createdAt])
  @@index([category, createdAt])
  @@index([projectId, createdAt])
}

model Project {
  id                         String              @id @default(uuid()) @db.Uuid
  slug                       String              @unique
  name                       String
  displayName                String?
  description                String?
  chainProjectId             BigInt              @unique
  onChainProjectPda          String              @unique
  ownerId                    String              @db.Uuid
  lowBalanceThresholdSol     Float?
  dailyRequestAlertThreshold Int?
  dailyCostAlertLamports     BigInt?
  templateType               String?
  archivedAt                 DateTime?
  environment                String              @default("development")
  starred                    Boolean             @default(false)
  notes                      String?
  notesUpdatedAt             DateTime?
  notesEditedByWallet        String?
  githubUrl                  String?
  isPublic                   Boolean             @default(false)
  publicSlug                 String?             @unique
  leaderboardVisible         Boolean             @default(false)
  dailyBudgetLamports        BigInt?
  monthlyBudgetLamports      BigInt?
  budgetWarningThresholdPct  Int?                @default(80)
  budgetHardStop             Boolean             @default(false)
  archiveReason              String?
  firstRequestCelebrationShown Boolean           @default(false)
  tags                       String[]            @default([])
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  owner                      User                @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  apiKeys                    ApiKey[]
  requestLogs                RequestLog[]
  nodes                      Node[]
  fundingRequests            FundingCoordinate[]
  usageRollups               ProjectUsageRollup[]
  walletActivities           WalletActivity[]
  rewardSnapshots            OperatorRewardSnapshot[]
  feedbackSubmissions        FeedbackSubmission[]
  notifications              Notification[]
  alertStates                AlertState[]
  webhooks                   Webhook[]
  members                    ProjectMember[]
  activityLogs               ActivityLog[]
  supportTickets             SupportTicket[]
  assistantMessages          AssistantMessage[]
  playgroundRecipes          PlaygroundRecipe[]

  @@index([ownerId])
  @@index([publicSlug])
}

model ApiKey {
  id          String       @id @default(uuid()) @db.Uuid
  projectId   String       @db.Uuid
  createdById String       @db.Uuid
  label       String
  colorTag    String?
  prefix      String       @unique
  keyHash     String       @unique
  status      ApiKeyStatus @default(ACTIVE)
  scopes      Json
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  requestLogs RequestLog[]

  @@index([projectId])
  @@index([createdById])
}

model RequestLog {
  id             String    @id @default(uuid()) @db.Uuid
  requestId      String?   @unique
  idempotencyKey String?
  projectId      String?   @db.Uuid
  apiKeyId       String?   @db.Uuid
  userId         String?   @db.Uuid
  service        String
  route          String
  method         String
  statusCode     Int
  durationMs     Int
  ipAddress      String?
  userAgent      String?
  region        String?
  requestSize   Int?
  responseSize  Int?
  upstreamNode  String?
  mode          String?
  simulated     Boolean   @default(false)
  cacheHit      Boolean?
  fyxvoHint     Json?
  createdAt      DateTime  @default(now())
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  apiKey         ApiKey?   @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([projectId, mode, createdAt])
  @@index([projectId, statusCode, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([userId, createdAt])
  @@index([service, route, createdAt])
  @@index([idempotencyKey])
}

model PlaygroundRecipe {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @db.Uuid
  name              String
  method            String
  mode              String   @default("standard")
  simulationEnabled Boolean  @default(false)
  params            Json
  notes             String?
  tags              String[] @default([])
  pinned            Boolean  @default(false)
  lastUsedAt        DateTime?
  sharedToken       String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, updatedAt])
  @@index([projectId, method])
  @@index([projectId, pinned, updatedAt])
}

model NodeOperator {
  id               String                   @id @default(uuid()) @db.Uuid
  name             String
  email            String                   @unique
  walletAddress    String                   @unique
  status           NodeOperatorStatus       @default(ONBOARDING)
  reputationScore  Float                    @default(1)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  nodes            Node[]
  rewardSnapshots  OperatorRewardSnapshot[]
}

model Node {
  id               String            @id @default(uuid()) @db.Uuid
  operatorId       String            @db.Uuid
  projectId        String?           @db.Uuid
  name             String
  network          NodeNetwork       @default(DEVNET)
  endpoint         String            @unique
  region           String
  status           NodeStatus        @default(PROVISIONING)
  reliabilityScore Float             @default(1)
  lastHeartbeatAt  DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  operator         NodeOperator      @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  metrics          Metrics[]
  healthChecks     NodeHealthCheck[]

  @@index([operatorId])
  @@index([projectId])
  @@index([network, status])
}

model Metrics {
  id           String   @id @default(uuid()) @db.Uuid
  nodeId       String   @db.Uuid
  cpuUsage     Float
  memoryUsage  Float
  diskUsage    Float
  requestCount Int
  errorRate    Float
  recordedAt   DateTime @default(now())
  node         Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, recordedAt])
}

model FundingCoordinate {
  id                  String   @id @default(uuid()) @db.Uuid
  projectId           String   @db.Uuid
  requestedById       String   @db.Uuid
  asset               String
  amount              BigInt
  recentBlockhash     String
  transactionBase64   String
  idempotencyKey      String   @unique
  transactionSignature String?  @unique
  confirmedAt         DateTime?
  createdAt           DateTime @default(now())
  expiresAt           DateTime
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy         User     @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([requestedById, createdAt])
}

model IdempotencyRecord {
  id           String   @id @default(uuid()) @db.Uuid
  key          String
  route        String
  method       String
  actorKey     String
  requestHash  String
  statusCode   Int
  responseBody Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime

  @@unique([key, method, route, actorKey])
  @@index([expiresAt])
}

model WorkerCursor {
  key         String   @id
  cursorValue Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectUsageRollup {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String?  @db.Uuid
  service         String
  windowStart     DateTime
  windowEnd       DateTime
  requestCount    Int
  successCount    Int
  errorCount      Int
  totalDurationMs Int
  averageLatencyMs Int
  lastRequestAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, service, windowStart, windowEnd])
  @@index([service, windowStart])
}

model WalletActivity {
  id             String    @id @default(uuid()) @db.Uuid
  walletAddress  String
  signature      String
  activityType   String
  slot           BigInt
  blockTime      DateTime?
  success        Boolean
  projectId      String?   @db.Uuid
  source         String
  raw            Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([walletAddress, signature])
  @@index([walletAddress, blockTime])
  @@index([projectId, blockTime])
}

model WalletTokenBalance {
  id            String   @id @default(uuid()) @db.Uuid
  walletAddress String
  mintAddress   String
  amount        String
  decimals      Int
  projectId     String?  @db.Uuid
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([walletAddress, mintAddress])
  @@index([projectId, walletAddress])
}

model TransactionLookup {
  id         String   @id @default(uuid()) @db.Uuid
  signature  String   @unique
  slot       BigInt
  status     String
  blockTime  DateTime?
  raw        Json
  fetchedAt  DateTime @default(now())
}

model NodeHealthCheck {
  id           String   @id @default(uuid()) @db.Uuid
  nodeId        String   @db.Uuid
  isHealthy     Boolean
  latencyMs     Int
  responseSlot  BigInt?
  errorMessage  String?
  checkedAt     DateTime @default(now())
  node          Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, checkedAt])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  projectId String?  @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, read])
}

model AlertState {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  projectId String?  @db.Uuid
  alertKey  String
  state     String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, alertKey])
  @@index([userId, state, updatedAt])
  @@index([projectId, updatedAt])
}

model DashboardPreference {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  widgetOrder  String[] @default([])
  hiddenWidgets String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model SavedView {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  kind      String
  name      String
  projectId String?  @db.Uuid
  filters   Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, kind, name])
  @@index([userId, kind, updatedAt])
  @@index([userId, kind, isDefault])
  @@index([projectId, updatedAt])
}

model UserBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  projectId String?  @db.Uuid
  label     String
  href      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, href])
  @@index([userId, updatedAt])
  @@index([projectId, updatedAt])
}

model FeedbackInboxTriage {
  id              String   @id @default(uuid()) @db.Uuid
  itemType        String
  itemId          String
  status          String   @default("new")
  tags            String[] @default([])
  updatedByUserId String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([itemType, itemId])
  @@index([status, updatedAt])
}

model OperatorRewardSnapshot {
  id               String       @id @default(uuid()) @db.Uuid
  operatorId       String       @db.Uuid
  projectId        String       @db.Uuid
  requestCount     Int
  uptimeRatio      Float
  reputationScore  Float
  rewardLamports   BigInt
  windowStart      DateTime
  windowEnd        DateTime
  createdAt        DateTime     @default(now())
  operator         NodeOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([operatorId, projectId, windowStart, windowEnd])
  @@index([projectId, windowEnd])
}

model ServiceHealthSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  serviceName    String
  status         String
  responseTimeMs Int?
  errorMessage   String?
  checkedAt      DateTime @default(now())

  @@index([serviceName, checkedAt])
}

model Incident {
  id          String    @id @default(uuid()) @db.Uuid
  serviceName String
  severity    String    @default("degraded")
  description String
  startedAt   DateTime  @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  updates     IncidentUpdate[]

  @@index([serviceName, startedAt])
  @@index([resolvedAt, startedAt])
}

model IncidentUpdate {
  id               String   @id @default(uuid()) @db.Uuid
  incidentId       String   @db.Uuid
  status           String   @default("update")
  severity         String?
  message          String
  affectedServices String[] @default([])
  createdAt        DateTime @default(now())
  incident         Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
  @@index([status, createdAt])
}

model ReferralClick {
  id                String   @id @default(uuid()) @db.Uuid
  referrerId        String   @db.Uuid
  clickedAt         DateTime @default(now())
  convertedToSignup Boolean  @default(false)
  referrer          User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId, clickedAt])
}

model Webhook {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String    @db.Uuid
  url             String
  events          Json
  secret          String
  active          Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliveries      WebhookDelivery[]

  @@index([projectId])
}

model ProjectMember {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @db.Uuid
  userId       String?   @db.Uuid
  role         String    @default("member")
  status       String    @default("active")
  invitedBy    String?   @db.Uuid
  invitedAt    DateTime  @default(now())
  acceptedAt   DateTime?
  inviteToken  String?   @unique
  inviteExpiry DateTime?
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model EnterpriseInterest {
  id                    String   @id @default(uuid()) @db.Uuid
  companyName           String
  contactEmail          String
  estimatedMonthlyReqs  String
  useCase               String
  createdAt             DateTime @default(now())

  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  userId    String?  @db.Uuid
  action    String
  details   Json?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([userId, createdAt])
}

model SystemAnnouncement {
  id        String   @id @default(uuid()) @db.Uuid
  message   String
  severity  String   @default("info")
  active    Boolean  @default(true)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, createdAt])
  @@index([active, startAt, endAt])
}

model WhatsNew {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String
  version     String
  publishedAt DateTime @default(now())
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, publishedAt])
}

model StatusSubscriber {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

model WebhookDelivery {
  id             String    @id @default(uuid()) @db.Uuid
  webhookId      String    @db.Uuid
  eventType      String
  payload        Json
  attemptNumber  Int       @default(1)
  status         String    @default("pending")
  responseStatus Int?
  responseBody   String?
  nextRetryAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  webhook        Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status, nextRetryAt])
}

model AssistantConversation {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @db.Uuid
  title         String
  pinned        Boolean            @default(false)
  archivedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  lastMessageAt DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      AssistantMessage[]
  feedback      AssistantFeedback[]

  @@index([userId, lastMessageAt])
  @@index([userId, pinned, lastMessageAt])
  @@index([userId, archivedAt, pinned, lastMessageAt])
}

model AssistantMessage {
  id             String                @id @default(uuid()) @db.Uuid
  conversationId String                @db.Uuid
  role           String
  content        String
  projectId      String?               @db.Uuid
  matchedDocsSection String?
  suggestedActions Json?
  playgroundPayload Json?
  promptCategory String?
  responseTimeMs Int?
  inputTokenEstimate Int?
  outputTokenEstimate Int?
  createdAt      DateTime              @default(now())
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  project        Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  feedback       AssistantFeedback?

  @@index([conversationId, createdAt])
  @@index([projectId])
  @@index([matchedDocsSection])
}

model AssistantFeedback {
  id             String                @id @default(uuid()) @db.Uuid
  userId         String                @db.Uuid
  conversationId String                @db.Uuid
  messageId      String                @unique @db.Uuid
  rating         String
  note           String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        AssistantMessage      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([rating, createdAt])
}

model PerformanceMetric {
  id        String   @id @default(uuid()) @db.Uuid
  pathname  String
  fcp       Float?   // First Contentful Paint ms
  lcp       Float?   // Largest Contentful Paint ms
  tti       Float?   // Time to Interactive ms
  ua        String?  // User agent category: "mobile" | "desktop" | "tablet"
  createdAt DateTime @default(now())

  @@index([pathname, createdAt])
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String   @db.Uuid
  projectId   String?  @db.Uuid
  category    String   @default("general")
  priority    String   @default("normal")
  subject     String
  description String
  status      String   @default("open")
  adminResponse String?
  adminRespondedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?

  user    User    @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([status])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String
  content     String
  publishedAt DateTime?
  visible     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([visible, publishedAt])
}

model NewsletterSubscriber {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  source    String   @default("landing")
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([email])
}

model DigestSchedule {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @unique @db.Uuid
  frequency  String    @default("weekly")
  lastSentAt DateTime?
  nextSendAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DigestRecord {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  generatedAt DateTime @default(now())
  htmlContent String
  sent        Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
